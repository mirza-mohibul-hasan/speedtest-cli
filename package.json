    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^12.0.0",
    "gradient-string": "^3.0.0",
    "ora": "^8.2.0"
